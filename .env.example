# Postgres connection string used by app/lib/db.ts
# Local:   postgres://USER:PASSWORD@localhost:5432/pcu_verify
# Managed: postgres://USER:PASSWORD@HOST:5432/DBNAME  (SSL auto-enabled)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pcu_verify

# Set to "disable" to turn off SSL for a managed host that doesn't need it.
# Local/127.0.0.1 connections skip SSL automatically.
# PGSSL=disable
